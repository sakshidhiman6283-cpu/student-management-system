class BankAccount:
    def __init__(self, account_no, name, balance=0):
        self.account_no = account_no
        self.name = name
        self.balance = balance

    def deposit(self, amount):
        if amount > 0:
            self.balance += amount
            print(f"₹{amount} deposited successfully.")
        else:
            print("Invalid amount!")

    def withdraw(self, amount):
        if amount <= 0:
            print("Invalid amount!")
        elif amount > self.balance:
            print("Insufficient Balance!")
        else:
            self.balance -= amount
            print(f"₹{amount} withdrawn successfully.")

    def check_balance(self):
        print(f"Current Balance: ₹{self.balance}")

    def display_details(self):
        print("\n----- Account Details -----")
        print(f"Account Number : {self.account_no}")
        print(f"Account Holder : {self.name}")
        print(f"Balance         : ₹{self.balance}")


class Bank:
    def __init__(self):
        self.accounts = {}

    def create_account(self):
        account_no = input("Enter Account Number: ")

        if account_no in self.accounts:
            print("Account already exists!")
            return

        name = input("Enter Account Holder Name: ")
        balance = float(input("Enter Initial Deposit: ₹"))

        self.accounts[account_no] = BankAccount(account_no, name, balance)
        print("Account Created Successfully!")

    def deposit_money(self):
        account_no = input("Enter Account Number: ")

        if account_no in self.accounts:
            amount = float(input("Enter Deposit Amount: ₹"))
            self.accounts[account_no].deposit(amount)
        else:
            print("Account Not Found!")

    def withdraw_money(self):
        account_no = input("Enter Account Number: ")

        if account_no in self.accounts:
            amount = float(input("Enter Withdraw Amount: ₹"))
            self.accounts[account_no].withdraw(amount)
        else:
            print("Account Not Found!")

    def check_balance(self):
        account_no = input("Enter Account Number: ")

        if account_no in self.accounts:
            self.accounts[account_no].check_balance()
        else:
            print("Account Not Found!")

    def account_details(self):
        account_no = input("Enter Account Number: ")

        if account_no in self.accounts:
            self.accounts[account_no].display_details()
        else:
            print("Account Not Found!")


bank = Bank()

while True:
    print("\n====== BANK MANAGEMENT SYSTEM ======")
    print("1. Create Account")
    print("2. Deposit Money")
    print("3. Withdraw Money")
    print("4. Check Balance")
    print("5. View Account Details")
    print("6. Exit")

    choice = input("Enter Your Choice: ")

    if choice == "1":
        bank.create_account()

    elif choice == "2":
        bank.deposit_money()

    elif choice == "3":
        bank.withdraw_money()

    elif choice == "4":
        bank.check_balance()

    elif choice == "5":
        bank.account_details()

    elif choice == "6":
        print("Thank You for Using Bank Management System!")
        break

    else:
        print("Invalid Choice! Please Try Again.")